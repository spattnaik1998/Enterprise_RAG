# ─────────────────────────────────────────────────────────────────────────────
# Enterprise RAG Pipeline -- Environment Variables
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Model APIs ────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-proj-..."
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ── Supabase (database, pgvector, chat logs) ────────────────────────────────
# Project URL: Supabase Dashboard > Settings > API > Project URL
SUPABASE_URL="https://xxxx.supabase.co"
# Service Role key (bypasses RLS — backend only, never expose to browser)
# Supabase Dashboard > Settings > API > service_role
SUPABASE_SERVICE_KEY="eyJ..."

# ── Client Portal Auth (JWT signing secret) ─────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="replace_with_64_char_hex_secret"

# ── LangSmith (observability + cost tracking) ────────────────────────────────
# Sign up at https://smith.langchain.com/
LANGSMITH_API_KEY="lsv2_pt_..."
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT="Enterprise RAG"
